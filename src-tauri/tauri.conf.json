{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SpotiLIE",
  "version": "0.1.0",
  "identifier": "com.spotilie.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://192.168.0.56:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": []
,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
